FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app

COPY package.json pnpm-workspace.yaml tsconfig.json ./
COPY packages ./packages
COPY services ./services

RUN pnpm install

RUN pnpm --filter @crypto-pulse/database exec prisma generate

RUN pnpm --filter @crypto-pulse/mcp-server run build

CMD pnpm --filter @crypto-pulse/mcp-server start
